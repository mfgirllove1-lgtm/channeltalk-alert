# ── Slack Bot Token 방식 (권장) ──────────────────────────────
# Slack 앱의 Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# 알림을 받을 Slack 채널 ID (예: C0AP0BRDZ9D)
SLACK_CHANNEL_ID=C0XXXXXXXXX

# ── Incoming Webhook 방식 (레거시 fallback) ──────────────────
# Bot Token이 설정되어 있으면 이 값은 무시됩니다
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── 채널톡 Webhook 서명 시크릿 ───────────────────────────────
# 채널톡 개발자 콘솔 > Webhook > Secret
CHANNELTALK_WEBHOOK_SECRET=your_channeltalk_webhook_secret
